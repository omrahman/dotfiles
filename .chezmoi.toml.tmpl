# This template runs on `chezmoi init` and writes ~/.config/chezmoi/chezmoi.toml.
# It prompts once for your git identity (values are remembered per machine).
{{- $name  := promptStringOnce . "name"  "Full name for git" -}}
{{- $email := promptStringOnce . "email" "Email for git" -}}

{{- /* On the machine where this repo lives at ~/repos/dotfiles, keep using it
       as chezmoi's source dir. Require the git metadata too, so a stale empty
       directory on a new machine does not override chezmoi's init clone. */}}
{{- $repo := joinPath .chezmoi.homeDir "repos" "dotfiles" }}
{{- $repoGit := joinPath $repo ".git" }}
{{- if stat $repoGit }}
sourceDir = {{ $repo | quote }}
{{- end }}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
