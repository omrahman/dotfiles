# ~/.zshrc — managed by chezmoi (source: dot_zshrc.tmpl)
# Edit the source with `chezmoi edit ~/.zshrc`, then `chezmoi apply`.

# --- PATH -------------------------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"

# --- Homebrew ---------------------------------------------------------------
# Works on both Apple Silicon (/opt/homebrew) and Intel (/usr/local) Macs.
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# --- fnm (Fast Node Manager) ------------------------------------------------
FNM_PATH="$(brew --prefix 2>/dev/null)/opt/fnm/bin"
if [ -d "$FNM_PATH" ]; then
  export PATH="$FNM_PATH:$PATH"
  eval "$(fnm env --shell zsh)"
fi

# --- History ----------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY          # share history across sessions
setopt HIST_IGNORE_ALL_DUPS   # drop older duplicate entries
setopt HIST_IGNORE_SPACE      # don't record commands starting with a space

# --- Completion -------------------------------------------------------------
autoload -Uz compinit && compinit

# --- Modern CLI tools (eza, bat) --------------------------------------------
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first'
  alias ll='eza -lah --git --group-directories-first'
  alias la='eza -a'
  alias lt='eza --tree --level=2'
else
  alias ll='ls -lah'
fi
if command -v bat >/dev/null 2>&1; then
  alias cat='bat'   # bat behaves like plain cat when output isn't a TTY (pipes)
fi

# --- Aliases ----------------------------------------------------------------
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
if command -v lazygit >/dev/null 2>&1; then
  alias lg='lazygit'   # standalone TUI; `git lg` (the log alias) is separate
fi

# --- Prompt (starship) ------------------------------------------------------
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# --- zoxide (smarter cd: `z <dir>`, `zi` for interactive pick) --------------
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# --- Local, untracked overrides ---------------------------------------------
# Put machine-specific secrets/tweaks here; this file is NOT managed by chezmoi.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
